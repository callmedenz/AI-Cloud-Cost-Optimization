# Run in simulation mode (no AWS calls)
USE_SIMULATION=true

# Optional: how often the backend refreshes metrics (seconds)
UPDATE_INTERVAL_SECONDS=300

# Recommended: use an AWS CLI profile instead of hardcoding keys
# AWS_PROFILE=default
# AWS_DEFAULT_REGION=ap-south-1

# Not recommended (avoid long-lived keys in files):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

